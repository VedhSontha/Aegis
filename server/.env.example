MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/aegis?retryWrites=true&w=majority
PORT=8080
CLIENT_ORIGIN=https://your-vercel-app.vercel.app
ALLOW_LOCAL_SCANS=false
SCAN_TIMEOUT_MS=8000
MAX_CONCURRENCY=4

# AI Security Analyst (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key
AEGIS_AI_MODEL=gemini-2.0-flash
